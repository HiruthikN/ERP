# MongoDB Connection String
# Option 1: Local MongoDB
# MONGO_URI=mongodb://localhost:27017/erp-system
# Option 2: MongoDB Atlas (Cloud - recommended, you can see data in browser)
# Go to https://cloud.mongodb.com → Create free cluster → Get connection string
MONGO_URI=mongodb://localhost:27017/erp-system

# JWT Secret Key (change this to any random string)
JWT_SECRET=erp-super-secret-key-change-this-in-production

# Server Port
PORT=5000

# Node Environment
NODE_ENV=development
